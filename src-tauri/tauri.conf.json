{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mTarsier",
  "version": "1.1.0",
  "identifier": "com.mtarsier",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "cd src-tauri && bash scripts/prepare-sidecar.sh release"
  },
  "app": {
    "windows": [
      {
        "title": "mTarsier",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mtarsier"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2RjQzQTUyMjY4NDc5QUUKUldTdWVZUW1VanIwMWk0R0xCbzh1Rjg1dDBoQ0xqZitoVzAreWtFaW9wT3Q1SnltUFF5YWFUU04K",
      "endpoints": ["https://mtarsier.com/api/updates/mcp-tarsier"],
      "windows": { "installMode": "passive" }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/tsr"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null
    }
  }
}
